# AASS-only database (Neon, Vercel Postgres, or a NEW Supabase project)
# Do NOT use Global Ticket Pay / iyfnoiqnyvwjyughdfym credentials here.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Required in production (random 32+ character string)
INCIDENT_FINGERPRINT_SALT=generate-a-long-random-string

# Local dev: writes to data/incidents.json when DATABASE_URL is unset
# INCIDENTS_STORAGE=file
